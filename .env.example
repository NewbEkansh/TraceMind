# ==============================
# TraceMind Environment Template
# ==============================

# ------------------------------
# API Security
# ------------------------------
API_SECRET_KEY=your_internal_api_key_here

# ------------------------------
# Supabase Configuration
# ------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key_here

# ------------------------------
# Blockchain (Ethereum Sepolia)
# ------------------------------
ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
PRIVATE_KEY=your_wallet_private_key_here
CONTRACT_ADDRESS=0xYourContractAddress

# ------------------------------
# Service URLs (Local Dev)
# ------------------------------
BACKEND_HOST=http://localhost:8000
ANALYTICS_HOST=http://localhost:8001

# ------------------------------
# Environment Mode
# ------------------------------
ENV=development
