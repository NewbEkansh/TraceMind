# --- Global & System ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log

# --- Python (FastAPI & AI Services) ---
# Protects services/api/venv and services/analytics/venv
**/venv/
**/env/
**/.env
**/*.pyc
**/__pycache__/
**/.pytest_cache/

# --- Node.js & Next.js (Web Dashboard) ---
# Protects apps/dashboard/node_modules
**/node_modules/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnp.*

# --- Next.js Build Artifacts ---
apps/dashboard/.next/
apps/dashboard/out/
apps/dashboard/build/
apps/dashboard/.env.local

# --- Flutter (Mobile App) ---
# Protects apps/mobile/build
**/build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
pubspec.lock

# --- Infrastructure & Secrets ---
# Never commit keys or wallet mnemonics
**/*.pem
**/*.key
infrastructure/contracts/artifacts/
infrastructure/contracts/cache/
